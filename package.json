{
  "name": "AniList-Desktop-Launcher",
  "version": "3.0.0",
  "description": "",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --windows"
  },
  "keywords": [],
  "author": "HypX2L, Bakaaa",
  "license": "CC BY-NC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@capacitor/status-bar": "^8.0.2",
    "systeminformation": "^5.31.6"
  },
  "build": {
    "appId": "com.hypx2l.anilistdesktop",
    "productName": "AniListDesktop",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "**/*",
      "!dist/*"
    ]
  }
}
